# SaveSong configuration — copy to .env (docker compose) or export in your shell.
# Every SAVESONG_* variable has a config.toml equivalent (~/.config/savesong/config.toml);
# precedence: CLI flag > environment > config.toml > built-in default.

SAVESONG_MUSIC_DIR=./music              # toml: music_dir
SAVESONG_DB_PATH=./data/savesong.db     # toml: db_path
SAVESONG_FORMAT=opus                    # toml: format — opus|m4a|mp3
SAVESONG_CONCURRENCY=4                  # toml: concurrency
SAVESONG_MATCH_THRESHOLD=0.72           # toml: match_threshold
SPOTIFY_CLIENT_ID=                      # toml: spotify_client_id — only needed for spotify source
SPOTIFY_CLIENT_SECRET=                  # toml: spotify_client_secret
REDIS_URL=redis://redis:6379/0          # toml: redis_url — web mode only
SAVESONG_WEB_PORT=8080                  # toml: web_port
